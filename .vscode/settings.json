{
    "editor.defaultFormatter": "dprint.dprint",
    "editor.formatOnSave": true,
    "files.autoSave": "onWindowChange",
    "files.associations": {
        "*.json5": "json5",
        "*.y*ml.j2": "yaml",
        "*.conf.j2": "properties",
        "alert.rules": "yaml",
    },
    "files.watcherExclude": {
      "**/.git/objects/**": true,
      "**/.git/subtree-cache/**": true,
      "**/node_modules/*/**": true,
      "**/.venv/*/**": true
    },
    "files.exclude": {
      "**/.git": true,
      "**/.svn": true,
      "**/.hg": true,
      "**/CVS": true,
      "**/.DS_Store": true,
      "**/Thumbs.db": true
    },
    "search.exclude": {
      "**/.git": true,
      "**/.venv": true,
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/node_modules": true,
      "**/.next": true,
      "**/dist": true,
      "**/build": true,
      "**/.cache": true,
      "**/logs": true,
      "**/*.log": true,
      "**/.nyc_output": true,
      "**/coverage": true,
      "**/.coverage": true,
      "**/htmlcov": true,
      "**/.tox": true,
      "**/.mypy_cache": true,
      "**/.ruff_cache": true,
      "**/target": true,
      "**/bin": true,
      "**/obj": true
    },
    "sops.defaults.ageKeyFile": "age.key",
    "[markdown]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "editor.formatOnSave": true
    },
    "terminal.integrated.defaultProfile.linux": "fish",
    "dprint.path": "/home/vscode/.local/share/mise/shims/dprint",
    "shellcheck.executablePath": "/home/vscode/.local/share/mise/shims/shellcheck",
    "shellformat.path": "/home/vscode/.local/share/mise/shims/shfmt",
    "sops.binPath": "/home/vscode/.local/share/mise/shims/sops",
    "yaml.schemas": {
        "https://taskfile.dev/schema.json": [
          "**/Taskfile.yml",
          "./path/to/any/other/taskfile.yml"
        ]
    },
    "yaml.validate": true,
    "yaml.customTags": [
        "!!python/name scalar"
    ],
    "git.postCommitCommand": "sync"
}
