{
  "name": "truenas-apps",
  "image": "mcr.microsoft.com/devcontainers/base:debian-12@sha256:23fa69fed758b7927c60061317d73baf7d66b9fca5c344e80bce3a940b229af0",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "sh -c \"$(curl -fsLS https://get.chezmoi.io)\" -- init --apply DevSecNinja && curl https://mise.run | sh && echo 'eval \"$(~/.local/bin/mise activate bash)\"' >> ~/.bashrc && ~/.local/bin/mise install && ~/.local/bin/mise exec -- lefthook install",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "blueglassblock.better-json5",
        "dprint.dprint",
        "foxundermoon.shell-format",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "signageos.signageos-vscode-sops",
        "timonwong.shellcheck"
      ],
      "settings": {
        "git.postCommitCommand": "none"
      }
    }
  }
}
