{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "pinDigests": true,
  "packageRules": [
    {
      "matchDepNames": ["jdx/mise"],
      "groupName": "mise"
    },
    {
      "matchDepNames": ["pgautoupgrade/pgautoupgrade", "postgres"],
      "groupName": "postgres"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/scripts/dccd\\.sh$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\nSOPS_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases"    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\n\\s+version: (?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-releases"    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.mise\\.toml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=(?<depName>\\S+)\\nmin_version = \"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases"    }
  ]
}
