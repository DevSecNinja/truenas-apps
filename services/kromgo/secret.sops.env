# Grafana Cloud Mimir endpoint with credentials embedded as URL userinfo.
# Format: https://<instance-id>:<access-policy-token>@<host>/api/prom
# Get from: Grafana Cloud → My Account → Stack → Prometheus → Details.
# Create a Cloud Access Policy token scoped to metrics:read only, named
# `kromgo-read`, so it can be revoked independently of the Alloy write token.
PROMETHEUS_URL=https://INSTANCE_ID:ACCESS_POLICY_TOKEN@prometheus-prod-XX-prod-REGION.grafana.net/api/prom
