{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    "github>DevSecNinja/truenas-apps//.renovate/autoMerge.json5",
    "github>DevSecNinja/truenas-apps//.renovate/customManagers.json5",
    "github>DevSecNinja/truenas-apps//.renovate/groups.json5",
    "github>DevSecNinja/truenas-apps//.renovate/labels.json5",
    "github>DevSecNinja/truenas-apps//.renovate/packageRules.json5",
    "github>DevSecNinja/truenas-apps//.renovate/semanticCommits.json5",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  pinDigests: true,
  timezone: 'Europe/Amsterdam',
  schedule: [
    'every weekend',
    'on Friday',
  ],
  ignorePaths: [
    '**/*.sops.*',
  ],
}
