# Ignore build artifacts and downloaded files
bin/**
site/

# Secrets
*.key
secret.env
.env
.config-hash.env
.decrypted~*

# Exclude directories that Git might not have permissions to
services/**/backups/
services/**/data/

# App specific
services/homepage/config/logs/

# Downloaded BATS helper libraries (installed by tests/setup_libs.sh)
tests/libs/

# BATS test report artifacts
report.xml

# go-task cache directory
.task/
