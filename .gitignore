# Ignore build artifacts and downloaded files
bin/**
site/

# BATS helper libraries (bootstrapped into place by tests/bootstrap.sh)
tests/libs/

# BATS test report artefacts
tests/*.xml
tests/**/*.xml
report.xml

# Secrets
*.key
secret.env
.env
.decrypted~*

# Exclude directories that Git might not have permissions to
services/**/backups/
services/**/data/

# App specific
services/homepage/config/logs/
